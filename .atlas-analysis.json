  "keyFeatures": [
    "Encrypted credential vault with master password",
    "Daily spend caps and rate limiting for LLM APIs",
    "Endpoint blocking to prevent dangerous operations",
    "Prompt drift detection with configurable alerting",
    "EIP-712 onchain permits for Web3 transactions",
    "Tamper-proof audit trail with Merkle trees",
    "ZK proof generation for compliance attestation",
    "Real-time alerts via webhooks",
    "Local-first architecture - credentials never leave your machine",
    "Built-in dashboard for monitoring and configuration"
  ],
